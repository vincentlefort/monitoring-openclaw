<!DOCTYPE html>
<html lang="fr" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monitoring OpenClaw - Vincent Lefort</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body {
            font-family: 'Segoe UI', system-ui, sans-serif;
            background-color: #0f172a;
            color: #f8fafc;
        }
        .card {
            background-color: #1e293b;
            border-radius: 0.75rem;
            padding: 1.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        }
        .status-running { color: #10b981; }
        .status-stopped { color: #ef4444; }
        .status-warning { color: #f59e0b; }
    </style>
</head>
<body class="min-h-screen p-4 md:p-8">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <header class="mb-8">
            <h1 class="text-3xl font-bold">🚀 Monitoring OpenClaw</h1>
            <p class="text-gray-400">Infrastructure de Vincent Lefort – Entrepreneur & Trader Crypto</p>
            <p class="text-sm text-gray-500 mt-2">Dernière mise à jour : <span id="last-update">Chargement...</span></p>
        </header>

        <!-- Services Status -->
        <section class="mb-8">
            <h2 class="text-2xl font-bold mb-4">📊 Statut des Services</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="card">
                    <h3 class="text-lg font-semibold mb-2">Bot Trading V5</h3>
                    <div class="flex items-center">
                        <div id="bot-status" class="status-running text-lg font-bold">Chargement...</div>
                        <div class="ml-4">
                            <div>Scans : <span id="scan-count">0</span></div>
                            <div>Positions : <span id="positions-count">0</span></div>
                        </div>
                    </div>
                    <p class="text-xs text-gray-500 mt-2">Données : ~/binance_bot_v5/bot_status_v5.json</p>
                </div>
                <div class="card">
                    <h3 class="text-lg font-semibold mb-2">Gateway OpenClaw</h3>
                    <div id="gateway-status" class="status-running text-lg font-bold">🟢 En ligne</div>
                    <p class="text-sm text-gray-400 mt-2">Connecté au réseau Tailscale</p>
                    <p class="text-xs text-gray-500 mt-1">Statut vérifié : <span id="gateway-check-time">maintenant</span></p>
                </div>
                <div class="card">
                    <h3 class="text-lg font-semibold mb-2">Crypto Confirm Bot</h3>
                    <div id="confirm-bot-status" class="status-running text-lg font-bold">🟢 Actif</div>
                    <p class="text-sm text-gray-400 mt-2">Surveillance des transactions Binance</p>
                    <p class="text-xs text-gray-500 mt-1">Dernière confirmation : <span id="last-confirmation">récente</span></p>
                </div>
            </div>
        </section>

        <!-- PnL & Capital -->
        <section class="mb-8">
            <h2 class="text-2xl font-bold mb-4">💰 Performance Financière</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div class="card">
                    <h3 class="text-lg font-semibold mb-2">PnL du Jour</h3>
                    <div id="daily-pnl" class="text-3xl font-bold text-green-400">$0.00</div>
                    <p class="text-sm text-gray-400 mt-2">Profit/Perte sur la session en cours</p>
                    <div id="pnl-info" class="text-xs text-gray-500 mt-1">
                        <span id="today-trades-count">0</span> trades aujourd'hui
                        <span id="pnl-calculated-badge" class="ml-2 px-2 py-1 bg-blue-900/50 text-blue-300 rounded text-xs hidden">
                            Calculé depuis trades
                        </span>
                    </div>
                </div>
                <div class="card">
                    <h3 class="text-lg font-semibold mb-2">Capital Actuel</h3>
                    <div id="capital" class="text-3xl font-bold text-blue-400">$0.00</div>
                    <p class="text-sm text-gray-400 mt-2">Capital total disponible</p>
                </div>
            </div>
        </section>

        <!-- Recent Trades -->
        <section class="mb-8">
            <h2 class="text-2xl font-bold mb-4">📈 Derniers Trades</h2>
            <div class="card overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-gray-700">
                            <th class="py-2 px-4 text-left">Date</th>
                            <th class="py-2 px-4 text-left">Symbol</th>
                            <th class="py-2 px-4 text-left">Direction</th>
                            <th class="py-2 px-4 text-left">Entry</th>
                            <th class="py-2 px-4 text-left">Exit</th>
                            <th class="py-2 px-4 text-left">PnL ($)</th>
                            <th class="py-2 px-4 text-left">PnL (%)</th>
                        </tr>
                    </thead>
                    <tbody id="trades-table">
                        <tr><td colspan="7" class="py-4 text-center">Chargement des trades...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Chart -->
        <section class="mb-8">
            <h2 class="text-2xl font-bold mb-4">📊 Évolution du Capital</h2>
            <div class="card">
                <canvas id="capital-chart"></canvas>
            </div>
        </section>

        <!-- Data Source Info -->
        <section class="mb-8 card">
            <h3 class="text-lg font-semibold mb-2">ℹ️ Source des Données</h3>
            <div class="text-sm text-gray-400">
                <p class="mb-2">Ce dashboard affiche des données en temps réel provenant de :</p>
                <ul class="list-disc pl-5 space-y-1">
                    <li><code class="bg-gray-800 px-1 rounded">~/binance_bot_v5/bot_status_v5.json</code> – Statut du bot trading</li>
                    <li><code class="bg-gray-800 px-1 rounded">~/binance_bot_v5/trades_v5.csv</code> – Historique des trades</li>
                    <li>Les données sont mises à jour via le script <code class="bg-gray-800 px-1 rounded">update-data.sh</code></li>
                </ul>
                <p class="mt-3 text-xs text-gray-500">Dernière mise à jour des fichiers source : <span id="data-source-update">inconnue</span></p>
            </div>
        </section>

        <!-- Footer -->
        <footer class="text-center text-gray-500 text-sm mt-8">
            <p>Monitoring OpenClaw – Vincent Lefort • Munich • <span id="current-time"></span></p>
            <p class="mt-2">Données mises à jour automatiquement toutes les 30 secondes • <a href="https://github.com/vincentlefort/monitoring-openclaw" class="text-blue-400 hover:text-blue-300">Voir sur GitHub</a></p>
        </footer>
    </div>

    <script>
        // Fonction pour formater les dates
        function formatDate(dateStr) {
            const date = new Date(dateStr);
            return date.toLocaleString('fr-FR', { 
                day: '2-digit', 
                month: '2-digit', 
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit'
            });
        }

        // Fonction pour formater les nombres
        function formatNumber(num, decimals = 2) {
            return num.toLocaleString('fr-FR', { 
                minimumFractionDigits: decimals, 
                maximumFractionDigits: decimals 
            });
        }

        // Fonction pour mettre à jour l'heure
        function updateTime() {
            const now = new Date();
            document.getElementById('current-time').textContent = 
                now.toLocaleString('fr-FR', { 
                    day: '2-digit', 
                    month: '2-digit', 
                    year: 'numeric',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit'
                });
        }

        // Fonction pour charger les données du bot
        async function loadBotData() {
            try {
                // Charger les données depuis GitHub
                const response = await fetch('https://raw.githubusercontent.com/vincentlefort/monitoring-openclaw/main/data/bot_status.json');
                if (!response.ok) throw new Error('Erreur HTTP ' + response.status);
                
                const botData = await response.json();

                // Mise à jour de l'interface
                document.getElementById('last-update').textContent = formatDate(botData.timestamp);
                document.getElementById('bot-status').textContent = botData.running ? '🟢 En cours' : '🔴 Arrêté';
                document.getElementById('bot-status').className = botData.running ? 'status-running text-lg font-bold' : 'status-stopped text-lg font-bold';
                document.getElementById('scan-count').textContent = botData.scan_count;
                document.getElementById('positions-count').textContent = botData.positions_count;
                
                // Mise à jour du PnL avec couleur selon le résultat
                const dailyPnlElement = document.getElementById('daily-pnl');
                const dailyPnlValue = botData.daily_pnl || 0;
                dailyPnlElement.textContent = '$' + formatNumber(dailyPnlValue);
                dailyPnlElement.className = dailyPnlValue >= 0 ? 'text-3xl font-bold text-green-400' : 'text-3xl font-bold text-red-400';
                
                document.getElementById('capital').textContent = '$' + formatNumber(botData.capital);
                
                // Afficher le nombre de trades d'aujourd'hui et l'indicateur de calcul
                if (botData.today_trades_count !== undefined) {
                    document.getElementById('today-trades-count').textContent = botData.today_trades_count;
                }
                
                if (botData.daily_pnl_calculated) {
                    document.getElementById('pnl-calculated-badge').classList.remove('hidden');
                }

                // Mise à jour du graphique
                updateChart(botData.capital);

                // Vérifier l'ancienneté des données
                checkDataFreshness(botData.timestamp);

            } catch (error) {
                console.error('Erreur lors du chargement des données du bot:', error);
                document.getElementById('bot-status').textContent = '❌ Erreur';
                document.getElementById('bot-status').className = 'status-warning text-lg font-bold';
                
                // Données de secours
                document.getElementById('daily-pnl').textContent = '$0.00';
                document.getElementById('capital').textContent = '$3,610.93';
                updateChart(3610.93);
            }
        }

        // Fonction pour vérifier l'ancienneté des données
        function checkDataFreshness(timestamp) {
            const dataTime = new Date(timestamp);
            const now = new Date();
            const diffMinutes = Math.floor((now - dataTime) / (1000 * 60));
            
            let freshnessText = '';
            let freshnessClass = 'text-green-400';
            
            if (diffMinutes < 5) {
                freshnessText = 'à l\'instant';
            } else if (diffMinutes < 60) {
                freshnessText = `il y a ${diffMinutes} min`;
                if (diffMinutes > 15) freshnessClass = 'text-yellow-400';
            } else if (diffMinutes < 1440) {
                const hours = Math.floor(diffMinutes / 60);
                freshnessText = `il y a ${hours}h`;
                freshnessClass = 'text-yellow-400';
            } else {
                const days = Math.floor(diffMinutes / 1440);
                freshnessText = `il y a ${days}j`;
                freshnessClass = 'text-red-400';
            }
            
            document.getElementById('data-source-update').textContent = freshnessText;
            document.getElementById('data-source-update').className = freshnessClass;
        }

        // Fonction pour charger les trades
        async function loadTrades() {
            try {
                // Charger les trades depuis GitHub
                const response = await fetch('https://raw.githubusercontent.com/vincentlefort/monitoring-openclaw/main/data/trades.json');
                if (!response.ok) throw new Error('Erreur HTTP ' + response.status);
                
                const allTrades = await response.json();
                
                // Prendre les 10 derniers trades
                const recentTrades = allTrades.slice(-10).reverse();

                const tableBody = document.getElementById('trades-table');
                tableBody.innerHTML = '';

                if (recentTrades.length === 0) {
                    tableBody.innerHTML = '<tr><td colspan="7" class="py-4 text-center text-gray-400">Aucun trade récent</td></tr>';
                    return;
                }

                recentTrades.forEach(trade => {
                    const row = document.createElement('tr');
                    row.className = 'border-b border-gray-800 hover:bg-gray-800/50';
                    
                    // Extraire les données nécessaires
                    const timestamp = trade.timestamp || trade.date || '';
                    const symbol = trade.symbol || '';
                    const direction = trade.direction || '';
                    const entryPrice = parseFloat(trade.entry_price || trade.entry || 0);
                    const exitPrice = parseFloat(trade.exit_price || trade.exit || 0);
                    const pnlUsdc = parseFloat(trade.pnl_usdc || trade.pnl || 0);
                    const pnlPct = parseFloat(trade.pnl_pct || trade.pnl_percent || 0);
                    
                    row.innerHTML = `
                        <td class="py-2 px-4">${formatDate(timestamp)}</td>
                        <td class="py-2 px-4 font-mono">${symbol}</td>
                        <td class="py-2 px-4">
                            <span class="${direction === 'LONG' ? 'text-green-400' : 'text-red-400'}">
                                ${direction}
                            </span>
                        </td>
                        <td class="py-2 px-4">${formatNumber(entryPrice, symbol.includes('BTC') ? 0 : 2)}</td>
                        <td class="py-2 px-4">${formatNumber(exitPrice, symbol.includes('BTC') ? 0 : 2)}</td>
                        <td class="py-2 px-4 ${pnlUsdc >= 0 ? 'text-green-400' : 'text-red-400'}">
                            ${pnlUsdc >= 0 ? '+' : ''}${formatNumber(pnlUsdc, 4)}
                        </td>
                        <td class="py-2 px-4 ${pnlPct >= 0 ? 'text-green-400' : 'text-red-400'}">
                            ${pnlPct >= 0 ? '+' : ''}${formatNumber(pnlPct, 2)}%
                        </td>
                    `;
                    tableBody.appendChild(row);
                });

            } catch (error) {
                console.error('Erreur lors du chargement des trades:', error);
                document.getElementById('trades-table').innerHTML = 
                    '<tr><td colspan="7" class="py-4 text-center text-red-400">Erreur de chargement des trades</td></tr>';
            }
        }

        // Graphique du capital
        let capitalChart;
        function updateChart(currentCapital) {
            const ctx = document.getElementById('capital-chart').getContext('2d');
            
            if (capitalChart) {
                capitalChart.destroy();
            }

            // Données simulées pour le graphique
            const labels = [];
            const data = [];
            let capital = 3500;
            
            for (let i = 0; i < 24; i++) {
                labels.push(`${i}h`);
                capital += (Math.random() - 0.5) * 20;
                data.push(capital);
            }
            data[data.length - 1] = currentCapital;

            capitalChart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: labels,
                    datasets: [{
                        label: 'Capital ($)',
                        data: data,
                        borderColor: '#3b82f6',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(255, 255, 255, 0.1)' },
                            ticks: { color: '#94a3b8' }
                        },
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.1)' },
                            ticks: { 
                                color: '#94a3b8',
                                callback: function(value) {
                                    return '$' + formatNumber(value);
                                }
                            }
                        }
                    }
                }
            });
        }

        // Fonction principale de mise à jour
        async function updateAllData() {
            await loadBotData();
            await loadTrades();
            updateTime();
        }

        // Initialisation
        document.addEventListener('DOMContentLoaded', () => {
            updateAllData();
            // Mise à jour toutes les 30 secondes
            setInterval(updateAllData, 30000);
            // Mise à jour de l'heure toutes les secondes
            setInterval(updateTime, 1000);
        });
    </script>
</body>
</html>